TELEGRAM_BOT_TOKEN=
# Claude auth — pick ONE of the following:
#   ANTHROPIC_API_KEY       — pay-as-you-go API credits (sk-ant-api...).
#   CLAUDE_CODE_OAUTH_TOKEN — long-lived token backed by a Claude Max/Pro
#                             subscription (sk-ant-oat...). Generate with
#                             `claude setup-token` from an authed machine.
# CLAUDE_CODE_OAUTH_TOKEN takes precedence when both are set.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=
ANTHROPIC_MODEL=claude-opus-4-6[1m]
HISTORY_DB_PATH=/data/history.sqlite
MEMORY_PATH=/data/memory.md
ATTACHMENTS_DIR=/data/attachments
PERSONA_PATH=prompts/flat_hunt.md
MAX_AGENT_TURNS=40
# Stream Claude's intermediate text blocks to the main chat as they
# arrive. Set to false to show only the final reply (useful in noisy
# group chats).
STREAM_INTERMEDIATE_TEXT=true
# Voice notes (optional) — OpenAI Whisper for transcribing Telegram voice notes.
OPENAI_API_KEY=
# Composio triggers (optional — leave unset to disable the webhook server).
COMPOSIO_WEBHOOK_SECRET=
TRIGGER_CHAT_ID=
# Voice call dispatch (optional) — shared secret for POST /voice/dispatch,
# called by ElevenLabs Conversational AI via its webhook-tool config.
VOICE_DISPATCH_SECRET=
# MCP proxy (optional) — if set, exposes /mcp as a transparent Streamable
# HTTP proxy that forwards to this upstream URL, forcing the compliant
# `Accept: application/json, text/event-stream` header. Use when an MCP
# client (e.g. ElevenLabs) sends a non-compliant Accept header and the
# upstream server rejects with 406.
MCP_PROXY_UPSTREAM=
PORT=8080
# Periodic self-nudge (optional — leave unset to disable). Uses
# TRIGGER_CHAT_ID as the target for any proactive replies.
SCHEDULE_INTERVAL_SECONDS=
# IANA timezone name (e.g. Europe/London) used when formatting timestamps
# shown to the agent. Defaults to UTC.
TIMEZONE=Europe/London
